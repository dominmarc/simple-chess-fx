<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.paint.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="mainPane" maxHeight="525.0" maxWidth="510.0" minHeight="525.0" minWidth="510.0" prefHeight="525.0" prefWidth="510.0" stylesheets="@LocalStyleFile.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="de.ifd.mad.SimpleChess.controller.MyLocalNetworkController">
	<children>
		<AnchorPane fx:id="buttonPane" layoutX="75.0" layoutY="92.0" maxHeight="360.0" maxWidth="360.0" minHeight="360.0" minWidth="360.0" prefHeight="360.0" prefWidth="360.0" />
      <Label fx:id="topBar" maxHeight="25.0" maxWidth="510.0" minHeight="25.0" minWidth="510.0" prefHeight="25.0" prefWidth="510.0" text="SimpleChess" textFill="WHITE">
         <font>
            <Font name="Berlin Sans FB" size="18.0" />
         </font>
      </Label>
      <Button fx:id="closeButton" layoutX="480.0" mnemonicParsing="false" onMouseClicked="#closeButtonClicked" prefHeight="25.0" prefWidth="30.0" text="X" textFill="WHITE" />
      <Button fx:id="minButton" layoutX="450.0" mnemonicParsing="false" onMouseClicked="#minButtonClicked" prefHeight="25.0" prefWidth="30.0" text="_" textFill="WHITE" />
      <Label fx:id="active1Label" layoutX="41.0" layoutY="35.0" maxHeight="20.0" minHeight="20.0" prefHeight="20.0" prefWidth="30.0" />
      <Label fx:id="active2Label" layoutX="41.0" layoutY="60.0" maxHeight="20.0" minHeight="20.0" prefHeight="20.0" prefWidth="30.0" />
      <Label fx:id="player1Text" layoutX="83.0" layoutY="32.0" maxHeight="25.0" minHeight="25.0" prefHeight="25.0" text="Player 1" textFill="WHITE">
         <font>
            <Font name="Berlin Sans FB" size="20.0" />
         </font></Label>
      <Label fx:id="player2Text" layoutX="82.0" layoutY="60.0" maxHeight="25.0" minHeight="25.0" prefHeight="25.0" text="Player 2" textFill="WHITE">

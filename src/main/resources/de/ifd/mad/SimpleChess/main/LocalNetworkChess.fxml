            <Font name="Berlin Sans FB" size="20.0" />
         </font>
         <textFill>
            <LinearGradient endX="0.5238095238095238" endY="0.1761904761904762" startX="0.5238095238095238" startY="0.5714285714285714">
               <stops>
                  <Stop color="#fbff02" />
                  <Stop color="#ffcc00" offset="1.0" />
               </stops>
            </LinearGradient>
         </textFill></Label>
      <Line endX="510.0" layoutY="25.0" />

            <Font name="Berlin Sans FB" size="20.0" />
         </font></Label>
      <Button fx:id="startButton" layoutX="326.0" layoutY="41.0" maxHeight="34.0" maxWidth="143.0" minHeight="25.0" minWidth="100.0" mnemonicParsing="false" onMouseClicked="#startButtonClicked" prefHeight="34.0" prefWidth="140.0" text="RESTART GAME">
